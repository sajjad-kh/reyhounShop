{
  "name": "ecommerce-platform",
  "version": "1.0.0",
  "description": "Complete e-commerce platform with Node.js, Express, and Prisma",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "bot": "nodemon src/services/bot/balebot.js",
    "dev:all": "concurrently -n BACK,BOT -c blue,green \"npm run dev\" \"npm run bot\"",
    "build": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "start:all": "concurrently \"npm start\" \"node ../server.js\"",
    "test": "jest --runInBand"
  },
  "keywords": [
    "ecommerce",
    "nodejs",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fontsource/vazirmatn": "^5.2.8",
    "@prisma/client": "^6.18.0",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "prisma": "^6.18.0",
    "qrcode.react": "^4.2.0",
    "speakeasy": "^2.0.0",
    "stripe": "^19.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "telegraf": "^4.16.3",
    "vazir-font": "^30.1.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.0",
    "@types/supertest": "^6.0.3",
    "concurrently": "^8.2.2",
    "jest": "^30.2.0",
    "nock": "^14.0.10",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
