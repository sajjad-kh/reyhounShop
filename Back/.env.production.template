# Production Environment Configuration Template
# Copy this file to .env.production and update with your production values
# 
# SECURITY WARNING: Never commit actual production values to version control!
# Use secure secret management systems for sensitive data in production.

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database Provider - Use MySQL for production
DATABASE_PROVIDER="mysql"

# MySQL Connection String
# Format: mysql://username:password@host:port/database_name
DATABASE_URL="mysql://ecommerce_user:secure_password@localhost:3306/ecommerce_production"

# Database Connection Pool Settings
DATABASE_CONNECTION_LIMIT=20
DATABASE_TIMEOUT=60000
DATABASE_RETRY_ATTEMPTS=3
DATABASE_RETRY_DELAY=1000
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Migration Settings
MIGRATE_FROM_SQLITE=false
SOURCE_DATABASE_URL="file:./prisma/dev.db"
TARGET_DATABASE_URL="mysql://ecommerce_user:secure_password@localhost:3306/ecommerce_production"
FORCE_MIGRATION=false

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server Settings
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
TRUST_PROXY=true

# Server Timeouts (milliseconds)
SERVER_TIMEOUT=30000
KEEP_ALIVE_TIMEOUT=5000
HEADERS_TIMEOUT=6000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Configuration - CRITICAL: Use strong secrets (64+ characters)
JWT_SECRET=your_very_long_production_secret_key_minimum_64_characters_change_this_immediately
JWT_EXPIRES_IN=7d
JWT_ALGORITHM=HS256
JWT_ISSUER=ecommerce-platform
JWT_AUDIENCE=ecommerce-users

# Password Hashing - Higher rounds for production
BCRYPT_SALT_ROUNDS=14

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# SSL Configuration
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/yourdomain.crt
SSL_KEY_PATH=/etc/ssl/private/yourdomain.key
SSL_CA_PATH=/etc/ssl/certs/ca-bundle.crt
SSL_PASSPHRASE=your_ssl_passphrase_if_needed

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

FRONTEND_URL=https://yourdomain.com

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================================================

# Zarinpal (Iranian Payment Gateway)
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ZARINPAL_SANDBOX=false

# Stripe (International Payments)
STRIPE_SECRET_KEY=sk_live_your_production_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_production_stripe_webhook_secret
STRIPE_API_VERSION=2023-10-16

# Pay.ir (Alternative Iranian Gateway)
PAYIR_API_KEY=your_production_payir_api_key
PAYIR_SANDBOX=false

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SMTP Settings
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_production_email_password

# Email Pool Settings
SMTP_MAX_CONNECTIONS=10
SMTP_MAX_MESSAGES=100
SMTP_RATE_DELTA=1000
SMTP_RATE_LIMIT=10

# Email Branding
EMAIL_FROM_NAME=Your E-commerce Platform
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# =============================================================================
# SMS CONFIGURATION
# =============================================================================

# Kavenegar SMS Service
KAVENEGAR_API_KEY=your_production_kavenegar_api_key
SMS_SENDER_NUMBER=your_production_sms_number

# SMS Templates (Kavenegar template IDs)
SMS_TEMPLATE_ORDER_CONFIRMATION=your_template_id
SMS_TEMPLATE_ORDER_STATUS=your_template_id
SMS_TEMPLATE_VERIFICATION=your_template_id

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# Cloudinary (Recommended for production)
CLOUDINARY_ENABLED=true
CLOUDINARY_CLOUD_NAME=your_production_cloud_name
CLOUDINARY_API_KEY=your_production_api_key
CLOUDINARY_API_SECRET=your_production_api_secret
CLOUDINARY_FOLDER=ecommerce-prod

# Local Upload (Backup option)
LOCAL_UPLOAD_ENABLED=false
LOCAL_UPLOAD_PATH=/var/uploads/ecommerce
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================

# Redis Configuration
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_KEY_PREFIX=ecommerce:prod:
REDIS_RETRY_DELAY=100
REDIS_MAX_RETRIES=3

# Cache TTL Settings (seconds)
CACHE_TTL_PRODUCTS=300
CACHE_TTL_CATEGORIES=600
CACHE_TTL_USERS=180
CACHE_TTL_ORDERS=60

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Levels: error, warn, info, debug
LOG_LEVEL=error
LOG_FORMAT=json

# File Logging
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/var/log/ecommerce/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5
LOG_FILE_DATE_PATTERN=YYYY-MM-DD

# Database Logging
LOG_DATABASE_ENABLED=true
LOG_DATABASE_BATCH_SIZE=100
LOG_DATABASE_FLUSH_INTERVAL=5000

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Sentry Error Tracking
SENTRY_ENABLED=true
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=5000

# Metrics Collection
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_COLLECT_DEFAULT=true

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Backup Schedule (cron format)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Local Backup
BACKUP_LOCAL_ENABLED=true
BACKUP_LOCAL_PATH=/var/backups/ecommerce

# S3 Backup
BACKUP_S3_ENABLED=true
BACKUP_S3_BUCKET=your-ecommerce-backups
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# =============================================================================
# API DOCUMENTATION
# =============================================================================

# Swagger Documentation (Disable in production for security)
ENABLE_SWAGGER=false
SWAGGER_PATH=/api-docs
SWAGGER_TITLE=E-commerce Platform API
SWAGGER_VERSION=1.0.0
SWAGGER_DESCRIPTION=Comprehensive e-commerce platform API

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Response Compression
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024

# Clustering
CLUSTERING_ENABLED=false
CLUSTER_WORKERS=4

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Core Features
FEATURE_2FA_ENABLED=true
FEATURE_LOYALTY_ENABLED=true
FEATURE_REVIEWS_ENABLED=true
FEATURE_WISHLIST_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true

# Analytics and Tracking
FEATURE_ANALYTICS_ENABLED=true

# =============================================================================
# 2FA CONFIGURATION
# =============================================================================

TWO_FA_SERVICE_NAME=Your E-commerce Platform
TWO_FA_ISSUER=YourCompany

# =============================================================================
# PRODUCTION DEPLOYMENT SETTINGS
# =============================================================================

# Deployment Configuration
DEPLOYMENT_ENVIRONMENT=production
DEPLOYMENT_VERSION=1.0.0
DEPLOYMENT_BUILD_NUMBER=1

# Process Management
PM2_INSTANCES=max
PM2_MAX_MEMORY_RESTART=1G
PM2_ERROR_FILE=/var/log/ecommerce/pm2-error.log
PM2_OUT_FILE=/var/log/ecommerce/pm2-out.log

# =============================================================================
# BASALAM API CONFIGURATION
# =============================================================================

# Basalam API Settings
BASALAM_API_URL=https://openapi.basalam.com
BASALAM_ORDER_API_URL=https://order.basalam.com
BASALAM_API_TOKEN=your_production_basalam_api_token_here

# Basalam Callback URL (must be publicly accessible)
BASALAM_CALLBACK_URL=https://yourdomain.com/api/v1/basalam/callback

# Basalam API Timeouts (milliseconds)
BASALAM_API_TIMEOUT=30000
BASALAM_API_RETRY_ATTEMPTS=3
BASALAM_API_RETRY_DELAY=1000

# Basalam Order Sync Settings
BASALAM_ORDER_SYNC_INTERVAL=30000
BASALAM_ORDER_CACHE_TTL=120

# =============================================================================
# SECURITY HEADERS AND POLICIES
# =============================================================================

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:
CSP_CONNECT_SRC='self'

# HSTS Settings
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true