// ================= PRISMA SCHEMA (UPDATED) =================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/**
 * ================= ENUMS =================
 */

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_REVIEW
  INFO
  DESIGNING
  DESIGN_REVIEW
  DESIGN_APPROVED
  PRINTING
  PACKAGING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentGateway {
  ZARINPAL
  STRIPE
  PAYIR
}

enum DiscountType {
  PERCENT
  FIXED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationType {
  ORDER_CONFIRMATION
  ORDER_STATUS_UPDATE
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PROMOTION
  WELCOME
  PASSWORD_RESET
}

enum DeliveryType {
  POST
  COURIER
  COD_POST
  COD_COURIER
}

enum DesignStatus {
  PENDING_DESIGN
  IN_DESIGN
  WAITING_APPROVAL
  APPROVED
  REVISION
  REJECTED
}

enum DesignVersionStatus {
  DRAFT
  SENT_TO_USER
  APPROVED
  NEED_CHANGE
}

enum AttachmentType {
  PAYMENT_RECEIPT
  REFERENCE_IMAGE
  DESIGN_FILE
}

enum MessageType {
  INITIAL_NOTE /// پیام اولیه هنگام سفارش
  DESIGN_FEEDBACK /// پیام بعد از دیدن طراحی
  ADMIN_REPLY /// پاسخ ادمین
  DESIGN_SUBMITTED /// طرح ارسال شد توسط ادمین
  DESIGN_APPROVED /// تایید توسط مشتری
  DESIGN_REVISION /// درخواست اصلاح
}

enum ReviewCommentStatus {
  PENDING
  APPROVED
  REJECTED
  APPROVED_IF_EMPTY
}

/**
 * ================= USER =================
 */

  enum AuthSessionStatus {
    PENDING
    APPROVED
    EXPIRED
  }

  model AuthSession {
    id String @id

    userId Int?
    user   User? @relation(fields: [userId], references: [id])

    status AuthSessionStatus @default(PENDING)

    telegramChatId String? @unique

    expiresAt DateTime
    createdAt DateTime @default(now())

    @@index([userId])
    @@index([telegramChatId])
  }

  model User {
    id Int @id @default(autoincrement())

    email String? @unique
    password String?

    phone String? @unique
    name String

    authProvider String @default("EMAIL") // 👈 مهم

    role     Role    @default(USER)
    isActive Boolean @default(true)

    is2FAEnabled Boolean @default(false)
    twoFASecret  String?

    loyaltyPoints Int @default(0)

    // relations
    addresses Address[]
    orders    Order[]
    cart      Cart?

    reviews  Review[]
    wishlist Wishlist[]

    logs ActivityLog[]

    notificationPreference NotificationPreference?
    notifications          Notification[]

    designVersions OrderDesignVersion[] @relation("DesignerVersions")
    designComments DesignComment[]

    messages        OrderMessage[]
    attachments     OrderAttachment[]
    statusHistories OrderStatusHistory[]
    designRevisions DesignRevision[] @relation("DesignerRevisions")

    // Bale login
    baleChatId String? @unique
    baleUsername String?
    baleFirstName String?
    baleConnectedAt DateTime?


    telegramId          BigInt?   @unique
    telegramUsername    String?
    telegramFirstName   String?
    telegramLastName    String?
    telegramConnectedAt DateTime?


    reviewsApproved Review[] @relation("ReviewApprover")

    authSessions AuthSession[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }




/**
 * ================= ADDRESS =================
 */

model Address {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  title      String
  fullName   String?
  phone      String?
  address    String
  city       String
  province   String
  postalCode String

  isDefault Boolean @default(false)

  orders Order[]
}

/**
 * ================= CATEGORY =================
 */

model Category {
  id Int @id @default(autoincrement())

  name     String
  parentId Int?

  parent   Category?  @relation("Subcategories", fields: [parentId], references: [id])
  children Category[] @relation("Subcategories")

  products Product[]
}

/**
 * ================= PRODUCT =================
 */

model Product {
  id Int @id @default(autoincrement())

  name        String
  slug        String  @unique
  description String?

  price         Int
  discountPrice Int?
  stock         Int

  reservedStock Int @default(0)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  images ProductImage[]

  lowStockAlert Int @default(5)

  shippingMethods ProductShippingMethod[]
  cartItems       CartItem[]
  orderItems      OrderItem[]

  reviews  Review[]
  wishlist Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  url    String
  isMain Boolean @default(false)
}

/**
 * ================= SHIPPING =================
 */

model ShippingMethod {
  id Int @id @default(autoincrement())

  basalamId Int? @unique

  name        String
  description String?

  baseCost                 Int
  additionalCost           Int  @default(0)
  additionalDimensionsCost Int?

  isPrivate Boolean @default(false)
  isActive  Boolean @default(true)

  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductShippingMethod[]
  orders   Order[]
}

model ProductShippingMethod {
  id Int @id @default(autoincrement())

  productId        Int
  shippingMethodId Int

  product        Product        @relation(fields: [productId], references: [id])
  shippingMethod ShippingMethod @relation(fields: [shippingMethodId], references: [id])

  @@unique([productId, shippingMethodId])
}

/**
 * ================= CART =================
 */

model Cart {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  items CartItem[]
}

model CartItem {
  id Int @id @default(autoincrement())

  cartId    Int
  productId Int

  cart    Cart    @relation(fields: [cartId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  quantity Int
}

/**
 * ================= ORDER =================
 */

model Order {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  status        OrderStatus   @default(PENDING_PAYMENT)
  paymentStatus PaymentStatus @default(PENDING)

  trackingCode String?

  totalPrice     Int
  shippingCost   Int
  discountAmount Int @default(0)

  addressId Int
  address   Address @relation(fields: [addressId], references: [id])

  deliveryType DeliveryType @default(POST)

  paymentRejectionReason String?

  shippingMethodId Int?
  shippingMethod   ShippingMethod? @relation(fields: [shippingMethodId], references: [id])

  items    OrderItem[]
  payments Payment[]

  // NEW
  messages      OrderMessage[]
  attachments   OrderAttachment[]
  statusHistory OrderStatusHistory[]

  // OLD (temporary keep)
  designFiles OrderDesignFile[]

  activityLogs ActivityLog[]

  designVersions OrderDesignVersion[] @relation("OrderDesignVersions")

  comments DesignComment[]

  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId   Int
  productId Int

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Int

  // NEW
  designStatus DesignStatus @default(PENDING_DESIGN)

  revisions DesignRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderMessage {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  userId  Int?
  isAdmin Boolean @default(false)

  type MessageType

  message String

  attachments OrderAttachment[]

  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model OrderAttachment {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  messageId Int?
  message   OrderMessage? @relation(fields: [messageId], references: [id])

  uploadedById Int?
  uploadedBy   User? @relation(fields: [uploadedById], references: [id])

  type AttachmentType

  url String

  originalName String?

  mimeType String?

  createdAt DateTime @default(now())
}

model DesignRevision {
  id Int @id @default(autoincrement())

  orderItemId Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  revision Int

  designerId Int?
  designer   User? @relation("DesignerRevisions", fields: [designerId], references: [id])

  designUrl String

  isApproved Boolean @default(false)

  feedback String?

  createdAt DateTime @default(now())
}

model OrderStatusHistory {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  changedById Int?
  changedBy   User? @relation(fields: [changedById], references: [id])

  fromStatus OrderStatus?
  toStatus   OrderStatus

  note String?

  createdAt DateTime @default(now())
}

/**
 * ================= DESIGN =================
 */

model OrderDesignFile {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  url  String
  type String

  createdAt DateTime @default(now())
}

model OrderDesignVersion {
  id Int @id @default(autoincrement())

  orderId Int

  order Order @relation("OrderDesignVersions", fields: [orderId], references: [id], onDelete: Cascade)

  version Int

  designerId Int?
  designer   User? @relation("DesignerVersions", fields: [designerId], references: [id])

  fileUrl String

  status DesignVersionStatus @default(DRAFT)

  isFinal Boolean @default(false)

  createdAt DateTime @default(now())
}

model DesignComment {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  message     String
  isFromAdmin Boolean @default(false)

  createdAt DateTime @default(now())
}

/**
 * ================= PAYMENT =================
 */

model Payment {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  amount Int
  status PaymentStatus @default(PENDING)

  gateway PaymentGateway

  gatewayRef    String?
  transactionId String?

  createdAt DateTime @default(now())
}

/**
 * ================= REVIEW / WISHLIST =================
 */

model Review {
  id Int @id @default(autoincrement())

  productId Int
  userId    Int
  orderId   Int?

  rating  Int
  comment String?

  isApproved Boolean @default(false)

  approvedAt DateTime?
  approvedBy Int?

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])

  approver User? @relation("ReviewApprover", fields: [approvedBy], references: [id])

  @@unique([userId, productId, orderId])
}

model Wishlist {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

/**
 * ================= NOTIFICATION =================
 */

model NotificationPreference {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(true)

  orderUpdates Boolean @default(true)
  promotions   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id Int @id @default(autoincrement())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  type    NotificationType
  channel NotificationChannel

  title   String
  message String

  status NotificationStatus @default(PENDING)

  scheduledAt DateTime?

  metadata Json?

  createdAt DateTime @default(now())
}

/**
 * ================= LOGS =================
 */
enum ActorType {
  USER
  ADMIN
  SYSTEM
}

model ActivityLog {
  id Int @id @default(autoincrement())

  // user relation
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // order relation
  orderId Int?
  order   Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  actorType ActorType @default(SYSTEM)

  action   String
  entity   String
  entityId Int?

  details Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
}

model ErrorLog {
  id          Int      @id @default(autoincrement())
  message     String
  stack       String?
  endpoint    String?
  method      String?
  ip          String?
  userId      Int?
  statusCode  Int?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model BankAccount {
  id          Int     @id @default(autoincrement())
  bankName    String
  holderName  String
  cardNumber  String
  sheba       String
  isActive    Boolean @default(true)
  priority    Int     @default(1)
}